@page
@model IndexModel
@{
    ViewData["Title"] = "Clinical Risk Analyzer";
}

<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/risk-analyzer.css" />


<div class="app-wrapper">
    <header class="app-header">
        <div class="logo">
            <div class="logo-icon">⚕</div>
            ClinicalRisk
        </div>
        <span class="badge">AI-Powered • RBQM Inspired</span>
    </header>

    <main class="main-content">
        <div class="page-title">
            <h1>Patient Risk Assessment</h1>
            <p>Enter patient data to generate an AI-powered clinical trial risk analysis</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error-box">
                ⚠️ @Model.ErrorMessage
            </div>
        }

        <div class="two-col">
            <div class="card">
                <div class="card-header">
                    <div class="dot"></div>
                    <h2>Patient Data</h2>
                </div>
                <div class="card-body">
                    <form method="post" id="riskForm">
                        <div class="form-group">
                            <label>Patient Name <span class="required">*</span></label>
                            <input type="text" name="PatientName" placeholder="e.g. Ahmed Hassan" required minlength="2" />
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label>Age <span class="required">*</span></label>
                                <input type="number" name="Age" placeholder="e.g. 45" required min="1" max="120" />
                                <div class="form-hint">Between 1 and 120</div>
                            </div>
                            <div class="form-group">
                                <label>Diagnosis <span class="required">*</span></label>
                                <input type="text" name="Diagnosis" placeholder="e.g. Type 2 Diabetes" required />
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Current Medications</label>
                            <input type="text" name="Medications" placeholder="e.g. Metformin 500mg, Aspirin 100mg" />
                            <div class="form-hint">Optional — separate multiple medications with commas</div>
                        </div>
                        <div class="form-group">
                            <label>Recent Lab Results</label>
                            <textarea name="LabResults" placeholder="e.g. HbA1c: 9.2%, Blood Pressure: 150/95, Cholesterol: 240mg/dL"></textarea>
                            <div class="form-hint">Optional — include any relevant test results</div>
                        </div>
                        <div class="form-group">
                            <label>Trial Protocol</label>
                            <input type="text" name="TrialProtocol" placeholder="e.g. Metformin Efficacy Study - Phase 3" />
                            <div class="form-hint">Optional — name or description of the trial</div>
                        </div>
                        <button type="submit" class="btn-analyze" id="submitBtn">
                            <span>⚕</span> Analyze Risk
                        </button>
                    </form>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="dot" style="background: @(string.IsNullOrEmpty(Model.RiskAssessment) ? "#94a3b8" : "#276749")"></div>
                    <h2>Risk Assessment</h2>
                </div>
                <div class="card-body" id="resultPanel">
                    @if (!string.IsNullOrEmpty(Model.RiskAssessment))
                    {
                        <div class="result-meta">
                            📋 Generated @DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm") UTC
                        </div>

                        string? riskClass = "risk-default";
                        string? riskLabel = "Assessment Ready";
                        string? lower = Model.RiskAssessment.ToLower();
                        if (lower.Contains("high risk") || lower.Contains("overall risk level: high") || lower.Contains("risk level**: high"))
                        { riskClass = "risk-high"; riskLabel = "High Risk"; }
                        else if (lower.Contains("medium risk") || lower.Contains("overall risk level: medium") || lower.Contains("risk level**: medium"))
                        { riskClass = "risk-medium"; riskLabel = "Medium Risk"; }
                        else if (lower.Contains("low risk") || lower.Contains("overall risk level: low") || lower.Contains("risk level**: low"))
                        { riskClass = "risk-low"; riskLabel = "Low Risk"; }

                        <span class="risk-badge @riskClass">● @riskLabel</span>

                        <div class="result-content">
                            @Html.Raw(Model.RiskAssessmentHtml)
                        </div>
                    }
                    else
                    {
                        <div class="result-empty" id="emptyState">
                            <div class="empty-icon">📋</div>
                            <p>Fill in the patient data and click<br/><strong>Analyze Risk</strong> to generate an assessment</p>
                        </div>
                    }

                    <div class="loading-box" id="loadingBox" style="display:none;">
                        <div class="spinner"></div>
                        <p>Analyzing patient data...</p>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    document.getElementById('riskForm').addEventListener('submit', function () {
        document.getElementById('submitBtn').disabled = true;
        document.getElementById('submitBtn').innerHTML = '⏳ Analyzing...';
        const resultPanel = document.getElementById('resultPanel');
        resultPanel.innerHTML = '<div class="loading-box"><div class="spinner"></div><p>Analyzing patient data...</p></div>';
    });
</script>
